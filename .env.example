# Copy this file to .env in this directory (project root) and set your values.
# Backend (deploy.sh) and app (send app) both read from here.
# Do not commit .env.

# --- Backend (AWS deploy) ---
# Your email domain (e.g. yourdomain.com). Must be verified in SES.
DOMAIN_NAME=
# Address to receive forwarded inbound mail (e.g. you@example.com)
INBOX_EMAIL=
# Optional: project name for CloudFormation resource names (default: custom-domain-email)
# PROJECT_NAME=custom-domain-email

# Optional: AWS region if using Route 53 for this domain (e.g. us-east-1)
# AWS_REGION=us-east-1
# Optional: Route 53 hosted zone ID — if set, stack creates SES identity + DKIM in Route 53
# HOSTED_ZONE_ID=

# --- App (send app) ---
# Comma-separated local parts for From dropdown (e.g. support,help → support@domain, help@domain). Only these addresses can be used as From.
FROM_LOCAL_PARTS=support,help

# SES SMTP credentials (from AWS SES → SMTP settings). Required for the send app.
SES_SMTP_HOST=
SES_SMTP_USER=
SES_SMTP_PASS=

# Optional: require ?key=SECRET to open the send app
# SEND_APP_SECRET=
# Optional: send app port (default 3333)
# SEND_APP_PORT=3333

